{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/dangerous-op-guard.mjs" },
          { "type": "command", "command": "node .claude/hooks/doc-sync-gate.mjs" },
          { "type": "command", "command": "node .claude/hooks/quality-gate.mjs" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/dangerous-op-guard.mjs" }
        ]
      }
    ]
  }
}
