{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["NODE_OPTIONS", "DATABASE_URL", "PHI_ENCRYPTION_KEY", "USE_HEADSHOTS"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vercel/output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
