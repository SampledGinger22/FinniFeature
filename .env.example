# Copy to .env (gitignored) for local development. Real secrets never get committed.

# Local Postgres from docker/docker-compose.yml (dev parity only). Host port 5434.
DATABASE_URL="postgres://finni:finni_local_dev@localhost:5434/finni"

# Field-level PHI encryption key (repository layer). Use a strong random value locally;
# in production this is provided by the platform secret store, never committed.
PHI_ENCRYPTION_KEY=""

# Force all PatientAvatars to the deterministic silhouette fallback (spec §8).
# Backend reads USE_HEADSHOTS; the web client only sees VITE_-prefixed vars, so it reads
# VITE_USE_HEADSHOTS. Set both alike. Either one "false" forces the fallback.
USE_HEADSHOTS="true"
VITE_USE_HEADSHOTS="true"
